# ── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (MySQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=roohbakhshac
DB_USERNAME=root
DB_PASSWORD=your_db_password_here
# synchronize فقط در development مجاز است (در production باید false باشد)
DB_SYNCHRONIZE=false

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Payment gateway ──────────────────────────────────────
# درگاه پرداخت ارزی (Stripe/PayPal/...) بعداً اینجا اضافه می‌شود.
# فعلاً درگاهی تنظیم نشده و پرداخت غیرفعال است.
