# ── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (MySQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=roohbakhsh
DB_USERNAME=root
DB_PASSWORD=

# synchronize فقط در development مجاز است (در production باید false باشد)
