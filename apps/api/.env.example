# ── Server ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database (MySQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=roohbakhshac
DB_USERNAME=root
DB_PASSWORD=change_me

# synchronize فقط در development مجاز است (در production باید false باشد)
DB_SYNCHRONIZE=false

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── ZarinPal ─────────────────────────────────────────────
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id
ZARINPAL_SANDBOX=true
PAYMENT_CALLBACK_BASE_URL=http://localhost:3001/api

# ── Mail (SMTP) ───────────────────────────────────────────
# اختیاری — اگر SMTP_HOST خالی بماند، ایمیل‌های بازیابی رمز/تأیید ایمیل فقط در لاگ سرور چاپ می‌شوند
# و واقعاً ارسال نمی‌شوند (مناسب توسعه‌ی لوکال بدون نیاز به SMTP واقعی).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@roohbakhsh.ac

# آدرس فرانت — برای ساخت لینک‌های reset-password / verify-email داخل ایمیل
FRONTEND_URL=http://localhost:3000
